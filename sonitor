#!/usr/bin/env bash
# Convenience wrapper so you can run `./sonitor ...` instead of
# `python3 sonitor.py ...`. Resolves its own directory, so it works from
# anywhere (including the cron entries created by `routine enable`).
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Prefer the project's virtualenv so dependencies resolve the same way whether
# run by hand or from cron. An explicit SONITOR_PYTHON still wins.
if [ -n "${SONITOR_PYTHON:-}" ]; then
    PYTHON="$SONITOR_PYTHON"
elif [ -x "$HERE/.venv/bin/python" ]; then
    PYTHON="$HERE/.venv/bin/python"
else
    PYTHON="python3"
fi

exec "$PYTHON" "$HERE/sonitor.py" "$@"
